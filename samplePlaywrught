import { test, expect } from '@playwright/test';

test('Reserve-Success', async ({ page }) => {
  await page.goto('http://localhost:3001/');



  await expect(page).toHaveTitle(' رزرو بلیت سینما');    //title
  await expect(page).toHaveURL('http://localhost:3001/')  //url

  await expect(
    page.getByRole('button', { name: 'رزرو' }).first()
  ).toBeEnabled();
  
  await expect(
    page.getByRole('button', { name: 'رزرو' }).first()
  ).toHaveText('رزرو');

  await expect(page.getByRole('button', { name: 'رزرو' }).first()).toBeVisible();
  await expect(page.getByRole('button', { name: 'رزرو' }).nth(1)).toBeVisible();
  await expect(page.getByRole('button', { name: 'رزرو' }).nth(2)).toBeVisible();

  await expect(page.getByText('Inception (صندلی باقیمانده: 1')).toContainText('باقیمانده');


  await page.getByRole('button', { name: 'رزرو' }).first().click();

  await expect(page).toHaveTitle( 'فرم رزرو');
  

  await page.locator('#seat-count').click();
  await page.locator('#seat-count').fill('1');

  await page.getByRole('button', { name: 'رزرو موقت' }).click();

  await page.locator('#user-name').click();
  await page.locator('#user-name').fill('zohre');
  await page.locator('#user-phone').click();
  await page.locator('#user-phone').fill('09151192344');
  await page.getByRole('button', { name: 'ثبت اطلاعات' }).click();
  await page.getByRole('button', { name: 'پرداخت و نهایی‌سازی' }).click();
  await expect(page.getByText('رزرو شما نهایی شد')).toContainText('رزرو شما نهایی شد');
  await expect(page.getByText('رزرو شما نهایی شد')).toBeVisible();
});

