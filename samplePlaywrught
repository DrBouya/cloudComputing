import { test, expect } from '@playwright/test';

test('test', async ({ page }) => {
  await page.goto('http://localhost:3001/');


  await expect(page).toHaveTitle(/فروشگاه نمونه/);
  await page.getByRole('button', { name: 'شروع خرید (ایجاد جلسه)' }).click();
  const text = await page.locator('#messages').textContent();

  const sessionId = text.replace('جلسه ایجاد شد:', '').trim();
  
  await expect(page.getByRole('button', { name: 'افزودن' }).first()).toBeEnabled();
  await expect(page.getByRole('button', { name: 'افزودن' }).nth(1)).toBeEnabled();
  await expect(page.getByRole('button', { name: 'افزودن' }).nth(2)).toBeEnabled();

  await page.getByRole('button', { name: 'افزودن' }).first().click();
  await page.getByRole('button', { name: 'افزودن' }).nth(1).click();
  await page.getByRole('button', { name: 'افزودن' }).nth(2).click();
  await page.getByRole('button', { name: 'رفتن به صندوق' }).click();
  await page.getByRole('link', { name: 'نمایش وضعیت جلسه' }).click();
 // await page.getByRole('textbox', { name: 'Session ID:' }).click();
  await page.getByRole('textbox', { name: 'Session ID:' }).fill(sessionId);
  await page.getByRole('button', { name: 'بررسی وضعیت' }).click();
});



